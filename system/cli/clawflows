_replace_block() {
  local new_block="$1"
  local tmpfile blockfile
  tmpfile="$(mktemp)"
  blockfile="$(mktemp)"

  printf '%s\n' "$new_block" > "$blockfile"

  awk -v start="$START_MARKER" -v end="$END_MARKER" -v bf="$blockfile" '
    $0 == start { while ((getline line < bf) > 0) print line; close(bf); skip=1; next }
    $0 == end   { skip=0; next }
    !skip       { print }
  ' "$AGENTS_MD" > "$tmpfile"

  mv "$tmpfile" "$AGENTS_MD"
  rm -f "$blockfile"
}

cmd_backup() {
  local filename="${1:-}"
  local timestamp
  timestamp="$(date +%Y-%m-%d-%H%M%S)"

  if [ -z "$filename" ]; then
    filename="clawflows-$timestamp.tar.gz"
  elif [[ "$filename" != *.tar.gz ]]; then
    filename="$filename.tar.gz"
  fi

  mkdir -p "$BACKUP_DIR"

  local tmpdir
  tmpdir="$(mktemp -d)"

  # Copy custom workflows
  if [ -d "$CUSTOM_DIR" ] && [ "$(ls -A "$CUSTOM_DIR" 2>/dev/null | grep -v '.gitkeep')" ]; then
    mkdir -p "$tmpdir/custom"
    for wf in "$CUSTOM_DIR"/*/; do
      [ -d "$wf" ] || continue
      local name="$(basename "$wf")"
      [ "$name" = ".gitkeep" ] && continue
      # Remove trailing slash to copy the directory itself, not just contents
      cp -r "${wf%/}" "$tmpdir/custom/"
    done
  else
    mkdir -p "$tmpdir/custom"
  fi

  # Save enabled workflows list
  : > "$tmpdir/enabled-workflows.txt"
  for link in "$ENABLED_DIR"/*/; do
    [ -d "$link" ] || continue
    local name="$(basename "$link")"
    [ "$name" = ".gitkeep" ] && continue
    echo "$name" >> "$tmpdir/enabled-workflows.txt"
  done

  # Create archive
  tar -czf "$BACKUP_DIR/$filename" -C "$tmpdir" .
  rm -rf "$tmpdir"

  # Count what we backed up
  local custom_count=0
  for wf in "$CUSTOM_DIR"/*/; do
    [ -d "$wf" ] || continue
    [ "$(basename "$wf")" = ".gitkeep" ] && continue
    ((custom_count++)) || true
  done

  local enabled_count=0
  for link in "$ENABLED_DIR"/*/; do
    [ -d "$link" ] || continue
    [ "$(basename "$link")" = ".gitkeep" ] && continue
    ((enabled_count++)) || true
  done

  echo ""
  echo "  Backup created"
  echo ""
  echo "    Custom workflows: $custom_count"
  echo "    Enabled workflows: $enabled_count"
  echo ""
  echo "    $BACKUP_DIR/$filename"
  echo ""
}

cmd_restore() {
  local file="${1:-}"

  # List available backups if none specified
  if [ -z "$file" ]; then
    if [ ! -d "$BACKUP_DIR" ] || [ -z "$(ls -A "$BACKUP_DIR" 2>/dev/null)" ]; then
      echo ""
      echo "  No backups found in $BACKUP_DIR"
      echo "  Run 'clawflows backup' to create one."
      echo ""
      return 1
    fi

    echo ""
    echo "  Available backups:"
    echo ""
    local i=1
    local backups=()
    # Sort newest first (reverse alphabetical since filenames have timestamps)
    for f in $(ls -r "$BACKUP_DIR"/*.tar.gz 2>/dev/null); do
      [ -f "$f" ] || continue
      backups+=("$f")
      local name="$(basename "$f")"
      if [ $i -eq 1 ]; then
        echo "    $i. $name (latest)"
      else
        echo "    $i. $name"
      fi
      ((i++))
    done

    if [ ${#backups[@]} -eq 0 ]; then
      echo "  No backups found."
      echo ""
      return 1
    fi

    echo ""
    printf "  Restore which backup? [1]: "
    read -r choice
    choice="${choice:-1}"

    if [[ ! "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt ${#backups[@]} ]; then
      echo "  Cancelled."
      return 1
    fi

    file="${backups[$((choice-1))]}"
  fi

  # Handle "latest"
  if [ "$file" = "latest" ]; then
    file="$(ls -r "$BACKUP_DIR"/*.tar.gz 2>/dev/null | head -1)"
    [ -n "$file" ] || die "no backups found"
  fi

  # Resolve relative path
  if [ ! -f "$file" ] && [ -f "$BACKUP_DIR/$file" ]; then
    file="$BACKUP_DIR/$file"
  fi

  [ -f "$file" ] || die "backup not found: $file"

  echo ""
  echo "  Restoring from $(basename "$file")..."

  local tmpdir
  tmpdir="$(mktemp -d)"
  tar -xzf "$file" -C "$tmpdir"

  # Restore custom workflows
  local restored=0
  local skipped=0
  if [ -d "$tmpdir/custom" ]; then
    for wf in "$tmpdir/custom"/*/; do
      [ -d "$wf" ] || continue
      local name="$(basename "$wf")"
      [ "$name" = ".gitkeep" ] && continue

      # Validate workflow name to prevent path traversal
      # Check for newlines first (same logic as validate_workflow_name)
      case "$name" in
        *$'\n'*)
          echo "  Warning: skipping invalid workflow name in backup: '$name' (contains newline)"
          continue
          ;;
      esac
      
      if ! printf '%s' "$name" | grep -qE '^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$'; then
        echo "  Warning: skipping invalid workflow name in backup: '$name'"
        continue
      fi

      if [ -d "$CUSTOM_DIR/$name" ]; then
        ((skipped++)) || true
      else
        # Remove trailing slash to copy the directory itself, not just contents
        cp -r "${wf%/}" "$CUSTOM_DIR/"
        ((restored++)) || true
      fi
    done
  fi

  # Re-enable workflows
  local enabled=0
  if [ -f "$tmpdir/enabled-workflows.txt" ]; then
    while IFS= read -r name || [ -n "$name" ]; do
      [ -z "$name" ] && continue
      
      # Validate workflow name to prevent path traversal
      # Check for newlines first (same logic as validate_workflow_name)
      case "$name" in
        *$'\n'*)
          echo "  Warning: skipping invalid workflow name in enabled list: '$name' (contains newline)"
          continue
          ;;
      esac
      
      if ! printf '%s' "$name" | grep -qE '^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$'; then
        echo "  Warning: skipping invalid workflow name in enabled list: '$name'"
        continue
      fi
      
      if [ -L "$ENABLED_DIR/$name" ] || [ -d "$ENABLED_DIR/$name" ]; then
        continue  # already enabled
      fi
      local source_dir
      source_dir="$(_find_workflow "$name")"
      if [ -n "$source_dir" ]; then
        ln -s "$source_dir" "$ENABLED_DIR/$name"
        ((enabled++)) || true
      fi
    done < "$tmpdir/enabled-workflows.txt"
  fi

  rm -rf "$tmpdir"

  # Sync AGENTS.md if we enabled anything
  if [ $enabled -gt 0 ]; then
    cmd_sync >/dev/null 2>&1 || true
  fi

  echo ""
  echo "  Restored $restored custom workflow(s)"
  [ $skipped -gt 0 ] && echo "  Skipped $skipped (already exist)"
  echo "  Enabled $enabled workflow(s)"
  echo ""
}

cmd_validate() {
  local name="$1"
  validate_workflow_name "$name"
  local wf_dir wf_file errors=0

  # Find the workflow
  wf_dir="$(_find_workflow "$name")"
  [ -n "$wf_dir" ] || die "workflow '$name' not found"

  wf_file="$wf_dir/WORKFLOW.md"
  [ -f "$wf_file" ] || die "WORKFLOW.md not found at $wf_file"

  echo ""
  echo "  Validating $name..."
  echo ""

  # Check frontmatter exists
  if ! head -1 "$wf_file" | grep -q '^---$'; then
    echo "  ✗ Missing frontmatter (file must start with ---)"
    errors=1
  fi

  # Check required fields
  local field_name field_emoji field_desc
  field_name="$(get_field "$wf_file" name)"
  field_emoji="$(get_field "$wf_file" emoji)"
  field_desc="$(get_field "$wf_file" description)"

  if [ -z "$field_name" ]; then
    echo "  ✗ Missing required field: name"
    errors=1
  else
    echo "  ✓ name: $field_name"
  fi

  if [ -z "$field_emoji" ]; then
    echo "  ✗ Missing required field: emoji"
    errors=1
  else
    echo "  ✓ emoji: $field_emoji"
  fi

  if [ -z "$field_desc" ]; then
    echo "  ✗ Missing required field: description"
    errors=1
  else
    echo "  ✓ description: $field_desc"
  fi

  echo ""

  if [ $errors -eq 0 ]; then
    echo "  ✓ Workflow is valid!"
    echo ""
    return 0
  else
    echo "  ✗ Validation failed"
    echo ""
    return 1
  fi
}

cmd_submit() {
  local name="$1"
  validate_workflow_name "$name"

  # Check if workflow exists in custom/
  if [ ! -d "$CUSTOM_DIR/$name" ]; then
    if [ -d "$COMMUNITY_DIR/$name" ]; then
      die "workflow '$name' is already a community workflow"
    fi
    die "workflow '$name' not found in custom/. Create one with: clawflows create"
  fi

  # Validate before submitting
  if ! cmd_validate "$name"; then
    die "fix validation errors before submitting"
  fi

  local source_dir="$CUSTOM_DIR/$name"
  local target_dir="$SUBMISSIONS_DIR/$name"

  # Check if already submitted
  if [ -d "$target_dir" ]; then
    die "workflow '$name' has already been submitted. Check $target_dir"
  fi

  # Copy to submissions
  mkdir -p "$SUBMISSIONS_DIR"
  cp -r "$source_dir" "$target_dir"

  echo ""
  echo "  Workflow copied to community-submissions/"
  echo ""

  # ── Auto-submit via gh CLI ──────────────────────────────────────────────
  # Check for gh CLI
  if ! command -v gh &>/dev/null; then
    echo "  ⚠️  gh CLI not found — install it for automatic PR submission:"
    echo "     brew install gh && gh auth login"
    echo ""
    echo "  Manual steps:"
    echo "  ─────────────────────────────────────────"
    echo "  1. Fork this repo: https://github.com/nikilster/clawflows/fork"
    echo "  2. git add community-submissions/$name"
    echo "     git commit -m \"Add $name workflow\""
    echo "     git push <your-fork-url> main"
    echo "  3. Open a PR: https://github.com/nikilster/clawflows/compare"
    echo ""
    return
  fi

  # Check gh auth
  if ! gh auth status &>/dev/null; then
    echo "  ⚠️  gh CLI not authenticated. Run: gh auth login"
    return
  fi

  # Get the upstream repo (owner/name) from origin
  local origin_url
  origin_url="$(git -C "$CLAWFLOWS_DIR" remote get-url origin 2>/dev/null || true)"
  local upstream_repo=""
  if [[ "$origin_url" =~ github\.com[:/]([^/]+/[^/.]+)(\.git)?$ ]]; then
    upstream_repo="${BASH_REMATCH[1]}"
  fi
  if [ -z "$upstream_repo" ]; then
    echo "  ⚠️  Could not detect upstream repo from origin URL."
    echo "  Submit manually: https://github.com/nikilster/clawflows/compare"
    return
  fi

  # Get current gh user
  local gh_user
  gh_user="$(gh api user --jq '.login' 2>/dev/null || true)"
  if [ -z "$gh_user" ]; then
    echo "  ⚠️  Could not detect GitHub username. Run: gh auth login"
    return
  fi

  local upstream_owner="${upstream_repo%%/*}"
  local repo_name="${upstream_repo##*/}"

  # Skip fork if user owns the upstream repo
  local fork_url=""
  if [ "$gh_user" = "$upstream_owner" ]; then
    fork_url="https://github.com/$upstream_repo.git"
    echo "  You own the upstream repo — pushing directly."
  else
    # Check if a proper fork already exists
    local is_fork
    is_fork="$(gh repo view "$gh_user/$repo_name" --json isFork --jq '.isFork' 2>/dev/null || echo "none")"

    if [ "$is_fork" = "true" ]; then
      echo "  Fork found: $gh_user/$repo_name"
    else
      # Either doesn't exist, is a redirect, or is a non-fork repo with the same name
      echo "  Creating fork..."
      if ! gh repo fork "$upstream_repo" --clone=false 2>/dev/null; then
        die "could not create fork. If $gh_user/$repo_name already exists as a non-fork repo, rename or delete it first."
      fi
      echo "  Fork created: $gh_user/$repo_name"
    fi
    fork_url="https://github.com/$gh_user/$repo_name.git"

    # Sync fork with upstream so branches are based on latest
    echo "  Syncing fork with upstream..."
    gh repo sync "$gh_user/$repo_name" --source "$upstream_repo" 2>/dev/null || true
  fi

  # Create a branch, commit, push
  local branch="submit/$name"
  local prev_branch
  prev_branch="$(git -C "$CLAWFLOWS_DIR" rev-parse --abbrev-ref HEAD)"

  echo "  Creating branch $branch..."
  git -C "$CLAWFLOWS_DIR" checkout -b "$branch" 2>/dev/null || git -C "$CLAWFLOWS_DIR" checkout "$branch" 2>/dev/null

  git -C "$CLAWFLOWS_DIR" add "community-submissions/$name"
  git -C "$CLAWFLOWS_DIR" commit -m "Add $name workflow" --quiet

  echo "  Pushing to fork..."
  git -C "$CLAWFLOWS_DIR" push "$fork_url" "$branch" --quiet 2>/dev/null

  # Open PR
  echo "  Opening pull request..."
  local pr_url
  if [ "$gh_user" = "$upstream_owner" ]; then
    pr_url="$(gh pr create --repo "$upstream_repo" \
      --head "$branch" \
      --title "Add $name workflow" \
      --body "## Workflow Submission

**Workflow name:** $name

**What does it do?**
$(get_field "$target_dir/WORKFLOW.md" description)

Submitted via \`clawflows submit\`." 2>/dev/null || true)"
  else
    pr_url="$(gh pr create --repo "$upstream_repo" \
      --head "$gh_user:$branch" \
      --title "Add $name workflow" \
      --body "## Workflow Submission

**Workflow name:** $name

**What does it do?**
$(get_field "$target_dir/WORKFLOW.md" description)

Submitted via \`clawflows submit\`." 2>/dev/null || true)"
  fi

  # Switch back to previous branch
  git -C "$CLAWFLOWS_DIR" checkout "$prev_branch" --quiet 2>/dev/null

  echo ""
  if [ -n "$pr_url" ]; then
    echo "  ✅ Pull request opened!"
    echo "  $pr_url"
  else
    echo "  ⚠️  Could not open PR automatically."
    echo "  Branch pushed — open a PR manually at:"
    echo "  https://github.com/$upstream_repo/compare/$branch"
  fi
  echo ""
  echo "  Thanks for contributing! 🍌"
  echo ""
}

cmd_share() {
  local name="${1:-}"
  local copy_flag="${2:-}"

  [ -n "$name" ] || die "usage: clawflows share <name>"

  # Handle --copy as first or second arg BEFORE validation
  if [ "$name" = "--copy" ]; then
    die "usage: clawflows share <name> [--copy]"
  fi

  validate_workflow_name "$name"

  local source_dir
  source_dir="$(_find_workflow "$name")"
  [ -n "$source_dir" ] || die "workflow '$name' not found"

  local wf_file="$source_dir/WORKFLOW.md"
  [ -f "$wf_file" ] || die "WORKFLOW.md not found at $wf_file"

  local emoji desc
  emoji="$(get_field "$wf_file" emoji)"
  desc="$(get_field "$wf_file" description)"

  local share_text="${emoji:+$emoji }$name
${desc:+$desc

}Get it: curl -fsSL https://raw.githubusercontent.com/nikilster/clawflows/main/system/install.sh | bash && clawflows enable $name"

  if [ "$copy_flag" = "--copy" ]; then
    if command -v pbcopy >/dev/null 2>&1; then
      printf '%s' "$share_text" | pbcopy
      echo "Copied to clipboard!"
    else
      echo "$share_text"
      echo ""
      echo "(pbcopy not available — text printed above)"
    fi
  else
    echo "$share_text"
  fi
}

cmd_import() {
  local url="${1:-}"

  [ -n "$url" ] || die "usage: clawflows import <url>"

  # Validate HTTPS
  case "$url" in
    https://*) ;;
    http://*)  die "only HTTPS URLs are supported (got HTTP)" ;;
    *)         die "invalid URL: $url (must start with https://)" ;;
  esac

  # Normalize GitHub blob URLs to raw
  # https://github.com/user/repo/blob/branch/path -> https://raw.githubusercontent.com/user/repo/branch/path
  local raw_url="$url"
  if echo "$raw_url" | grep -q '^https://github\.com/.*/blob/'; then
    raw_url="$(echo "$raw_url" | sed 's|^https://github\.com/\([^/]*/[^/]*\)/blob/|https://raw.githubusercontent.com/\1/|')"
  fi

  # Normalize gist URLs to raw
  # https://gist.github.com/user/id -> https://gist.githubusercontent.com/user/id/raw
  if echo "$raw_url" | grep -q '^https://gist\.github\.com/'; then
    raw_url="$(echo "$raw_url" | sed 's|^https://gist\.github\.com/|https://gist.githubusercontent.com/|')"
    # Append /raw if not already present
    case "$raw_url" in
      */raw|*/raw/) ;;
      *) raw_url="${raw_url}/raw" ;;
    esac
  fi

  # Download to temp file
  local tmpfile
  tmpfile="$(mktemp)"
  trap "rm -f '$tmpfile'" EXIT

  if ! curl -fsSL "$raw_url" -o "$tmpfile" 2>/dev/null; then
    rm -f "$tmpfile"
    die "failed to download from $raw_url"
  fi

  # Validate frontmatter
  local wf_name wf_emoji wf_desc
  wf_name="$(get_field "$tmpfile" name)"
  wf_emoji="$(get_field "$tmpfile" emoji)"
  wf_desc="$(get_field "$tmpfile" description)"

  [ -n "$wf_name" ] || { rm -f "$tmpfile"; die "downloaded file is missing required 'name' field in frontmatter"; }
  [ -n "$wf_desc" ] || { rm -f "$tmpfile"; die "downloaded file is missing required 'description' field in frontmatter"; }

  # Show what was downloaded and warn about external source
  echo ""
  echo "  ${wf_emoji:+$wf_emoji }$wf_name"
  [ -n "$wf_desc" ] && echo "  $wf_desc"
  echo ""
  echo "  ! Downloaded from: $url"
  echo "  ! Review workflows before enabling — they run with your agent's permissions."
  echo ""
  printf "  Save this workflow? [y/N] "
  read -r save_confirm
  if [ "$save_confirm" != "y" ] && [ "$save_confirm" != "Y" ]; then
    echo "  Cancelled."
    rm -f "$tmpfile"
    return
  fi

  # Check for conflicts
  local dest_dir="$CUSTOM_DIR/$wf_name"
  if [ -d "$dest_dir" ]; then
    printf "  workflow '$wf_name' already exists in custom/. Overwrite? [y/N] "
    read -r confirm
    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
      echo "  Cancelled."
      rm -f "$tmpfile"
      return
    fi
  fi

  # Save to custom/
  mkdir -p "$dest_dir"
  cp "$tmpfile" "$dest_dir/WORKFLOW.md"
  rm -f "$tmpfile"
  trap - EXIT

  echo "  Saved to custom/$wf_name"

  # Offer to enable
  printf "  Enable this workflow? [Y/n] "
  read -r enable_confirm
  if [ "$enable_confirm" != "n" ] && [ "$enable_confirm" != "N" ]; then
    cmd_enable "$wf_name"
  else
    echo ""
    echo "  Enable later with: clawflows enable $wf_name"
    echo ""
  fi
}

cmd_run() {
  local name="$1"
  validate_workflow_name "$name"
  local wf_file

  # Find the workflow
  if [ -L "$ENABLED_DIR/$name" ] || [ -d "$ENABLED_DIR/$name" ]; then
    wf_file="$ENABLED_DIR/$name/WORKFLOW.md"
  elif [ -d "$CUSTOM_DIR/$name" ]; then
    # Auto-enable if in custom but not enabled
    echo "Enabling $name..."
    cmd_enable "$name"
    wf_file="$ENABLED_DIR/$name/WORKFLOW.md"
  elif [ -d "$COMMUNITY_DIR/$name" ]; then
    # Auto-enable if in community but not enabled
    echo "Enabling $name..."
    cmd_enable "$name"
    wf_file="$ENABLED_DIR/$name/WORKFLOW.md"
  else
    die "workflow '$name' not found"
  fi

  [ -f "$wf_file" ] || die "WORKFLOW.md not found at $wf_file"

  # Set up run log file
  local today time_now run_dir run_file
  today="$(date +%Y-%m-%d)"
  time_now="$(date +%H:%M)"
  run_dir="$CLAWFLOWS_DIR/system/runs/$today/$name"
  run_file="$run_dir/$time_now"
  mkdir -p "$run_dir"

  # Run via openclaw if available
  local oc
  oc="$(_find_openclaw)"
  if [ -n "$oc" ]; then
    echo "Running $name — check your chat with your agent for results."
    echo ""
    local cf_agent
    cf_agent="${CLAWFLOWS_OPENCLAW_AGENT:-main}"
    "$oc" agent --agent "$cf_agent" -m "Run the $name workflow by following $wf_file" | tee "$run_file"
  else
    echo ""
    echo "  ✓ Workflow ready: $name"
    echo ""
    echo "  To run it, tell your agent:"
    echo ""
    echo "    Run $name"
    echo ""
    touch "$run_file"
  fi
}

# ── Logs ──────────────────────────────────────────────────────────────────────

cmd_logs() {
  local filter_name="${1:-}"
  [ -n "$filter_name" ] && validate_workflow_name "$filter_name"
  local filter_date="${2:-}"
  local runs_dir="$CLAWFLOWS_DIR/system/runs"

  if [ ! -d "$runs_dir" ]; then
    echo "No runs yet."
    return
  fi

  local count=0
  local max=20

  # Walk date directories newest-first
  for date_dir in $(ls -1r "$runs_dir" 2>/dev/null); do
    case "$date_dir" in
      [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]) ;;
      *) continue ;;
    esac
    [ -d "$runs_dir/$date_dir" ] || continue

    # Filter by date if specified
    if [ -n "$filter_date" ] && [ "$date_dir" != "$filter_date" ]; then
      continue
    fi

    # Collect time entries for this date, then sort newest-first
    local entries=""
    for wf_dir in "$runs_dir/$date_dir"/*/; do
      [ -d "$wf_dir" ] || continue
      local wf_name
      wf_name="$(basename "$wf_dir")"

      # Filter by name if specified
      if [ -n "$filter_name" ] && [ "$wf_name" != "$filter_name" ]; then
        continue
      fi

      for time_file in "$wf_dir"*; do
        [ -e "$time_file" ] || continue
        local time_name
        time_name="$(basename "$time_file")"
        entries="${entries}${time_name}|${wf_name}|${time_file}
"
      done
    done

    # Sort entries by time descending
    local sorted
    sorted="$(echo "$entries" | sort -r)"

    local IFS_OLD="$IFS"
    IFS=$'\n'
    for entry in $sorted; do
      [ -n "$entry" ] || continue
      local t_name w_name t_file
      t_name="$(echo "$entry" | cut -d'|' -f1)"
      w_name="$(echo "$entry" | cut -d'|' -f2)"
      t_file="$(echo "$entry" | cut -d'|' -f3)"

      # Look up emoji
      local emoji=""
      local source_dir
      source_dir="$(_find_workflow "$w_name" 2>/dev/null || true)"
      if [ -n "$source_dir" ] && [ -f "$source_dir/WORKFLOW.md" ]; then
        emoji="$(get_field "$source_dir/WORKFLOW.md" emoji)"
      fi
      emoji="${emoji:-📄}"

      echo "─── $date_dir $t_name $emoji $w_name ───"

      # Show log content or placeholder
      if [ -s "$t_file" ]; then
        cat "$t_file"
      else
        echo "(no log recorded)"
      fi
      echo ""

      count=$((count + 1))
      if [ "$count" -ge "$max" ]; then
        IFS="$IFS_OLD"
        return
      fi
    done
    IFS="$IFS_OLD"
  done

  if [ "$count" -eq 0 ]; then
    if [ -n "$filter_name" ]; then
      echo "No runs found for '$filter_name'."
    else
      echo "No runs yet."
    fi
  fi
}

# ── Dashboard ────────────────────────────────────────────────────────────────

# Build JSON array of all workflows (single awk pass for speed)
_build_dashboard_json() {
  # Collect all workflow files with metadata: source|enabled|filepath
  local manifest=""
  local seen_names=""

  # Custom workflows first
  for dir in "$CUSTOM_DIR"/*/; do
    [ -d "$dir" ] || continue
    local name
    name="$(basename "$dir")"
    [ "$name" = ".gitkeep" ] && continue
    [ -f "$dir/WORKFLOW.md" ] || continue
    seen_names="$seen_names $name "

    local enabled="false"
    if [ -L "$ENABLED_DIR/$name" ] || [ -d "$ENABLED_DIR/$name" ]; then
      enabled="true"
    fi
    manifest="$manifest
custom|$enabled|${dir%/}/WORKFLOW.md"
  done

  # Community workflows (skip overridden by custom)
  for dir in "$COMMUNITY_DIR"/*/; do
    [ -d "$dir" ] || continue
    local name
    name="$(basename "$dir")"
    [ -f "$dir/WORKFLOW.md" ] || continue
    case "$seen_names" in
      *" $name "*) continue ;;
    esac

    local enabled="false"
    if [ -L "$ENABLED_DIR/$name" ] || [ -d "$ENABLED_DIR/$name" ]; then
      enabled="true"
    fi
    manifest="$manifest
community|$enabled|${dir%/}/WORKFLOW.md"
  done

  # No workflows? Fast path
  if [ -z "$manifest" ]; then
    printf '[]'
    return
  fi

  # Single awk reads all files and outputs the full JSON array
  printf '%s\n' "$manifest" | awk '
    function json_esc(s,   i, c, out) {
      out = ""
      for (i = 1; i <= length(s); i++) {
        c = substr(s, i, 1)
        if (c == "\\") out = out "\\\\"
        else if (c == "\"") out = out "\\\""
        else if (c == "\t") out = out "\\t"
        else out = out c
      }
      return out
    }

    BEGIN { first = 1; printf "[" }

    /^$/ { next }

    {
      # Parse manifest line: source|enabled|filepath
      n = split($0, parts, "|")
      src = parts[1]; ena = parts[2]; fp = parts[3]

      # Derive name from path: .../name/WORKFLOW.md
      gsub(/\/WORKFLOW\.md$/, "", fp)
      name = fp; sub(/.*\//, "", name)
      fp = fp "/WORKFLOW.md"

      emoji = ""; desc = ""; sched = ""; author = ""; content = ""
      in_fm = 0; past_fm = 0
      while ((getline line < fp) > 0) {
        if (line == "---") { in_fm++; if (in_fm >= 2) past_fm = 1; continue }
        if (in_fm == 1 && !past_fm) {
          if (line ~ /^emoji:/) { val = line; sub(/^emoji:[ ]*/, "", val); gsub(/^["'"'"']|["'"'"']$/, "", val); emoji = val }
          else if (line ~ /^description:/) { val = line; sub(/^description:[ ]*/, "", val); gsub(/^["'"'"']|["'"'"']$/, "", val); desc = val }
          else if (line ~ /^schedule:/) { val = line; sub(/^schedule:[ ]*/, "", val); gsub(/^["'"'"']|["'"'"']$/, "", val); sched = val }
          else if (line ~ /^author:/) { val = line; sub(/^author:[ ]*/, "", val); gsub(/^["'"'"']|["'"'"']$/, "", val); author = val }
        }
        if (past_fm) {
          if (content != "") content = content "\\n" json_esc(line)
          else content = json_esc(line)
        }
      }
      close(fp)

      if (!first) printf ","
      printf "{\"name\":\"%s\",\"emoji\":\"%s\",\"description\":\"%s\",\"schedule\":\"%s\",\"author\":\"%s\",\"source\":\"%s\",\"enabled\":%s,\"content\":\"%s\"}", \
        json_esc(name), emoji, json_esc(desc), json_esc(sched), json_esc(author), src, ena, content
      first = 0
    }

    END { printf "]" }
  '
}

_build_runs_json() {
  local runs_dir="$CLAWFLOWS_DIR/system/runs"

  # Fast path: no runs directory
  if [ ! -d "$runs_dir" ]; then
    printf '[]'
    return
  fi

  local first=true
  printf '['

  # Walk date directories newest-first
  for date_dir in $(ls -1r "$runs_dir" 2>/dev/null); do
    # Validate YYYY-MM-DD format
    case "$date_dir" in
      [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]) ;;
      *) continue ;;
    esac
    [ -d "$runs_dir/$date_dir" ] || continue

    # Walk workflow directories
    for wf_dir in "$runs_dir/$date_dir"/*/; do
      [ -d "$wf_dir" ] || continue
      local wf_name
      wf_name="$(basename "$wf_dir")"

      # Walk time files
      for time_file in "$wf_dir"*; do
        [ -e "$time_file" ] || continue
        local time_name
        time_name="$(basename "$time_file")"

        # Read log content if file is non-empty
        local log_content=""
        if [ -s "$time_file" ]; then
          log_content="$(cat "$time_file")"
          # Escape for JSON: backslashes, quotes, newlines, tabs
          log_content="$(printf '%s' "$log_content" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g' | awk '{printf "%s\\n", $0}' | sed 's/\\n$//')"
        fi

        if $first; then
          first=false
        else
          printf ','
        fi
        printf '{"date":"%s","workflow":"%s","time":"%s","log":"%s"}' "$date_dir" "$wf_name" "$time_name" "$log_content"
      done
    done
  done

  printf ']'
}

_dashboard_state_file() {
  echo "$CLAWFLOWS_DIR/system/.dashboard-state"
}

_dashboard_is_running() {
  local state_file
  state_file="$(_dashboard_state_file)"
  [ -f "$state_file" ] || return 1
  local pid
  pid="$(head -1 "$state_file")"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

_dashboard_stop() {
  local state_file
  state_file="$(_dashboard_state_file)"
  if [ -f "$state_file" ]; then
    local pid
    pid="$(head -1 "$state_file")"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
      echo "Dashboard stopped"
    else
      echo "Dashboard was not running"
    fi
    rm -f "$state_file"
  else
    echo "Dashboard is not running"
  fi
}

cmd_dashboard() {
  local flag="${1:-}"

  # --json flag: output workflow JSON to stdout (used by server.js)
  if [ "$flag" = "--json" ]; then
    _build_dashboard_json
    return
  fi

  # --runs-json flag: output run history JSON to stdout (used by server.js)
  if [ "$flag" = "--runs-json" ]; then
    _build_runs_json
    return
  fi

  # stop subcommand
  if [ "$flag" = "stop" ]; then
    _dashboard_stop
    return
  fi

  # status subcommand
  if [ "$flag" = "status" ]; then
    if _dashboard_is_running; then
      local url
      url="$(tail -1 "$(_dashboard_state_file)")"
      echo "Dashboard running at $url"
    else
      echo "Dashboard is not running"
      rm -f "$(_dashboard_state_file)"
    fi
    return
  fi

  # If already running, just open the browser
  if _dashboard_is_running; then
    local url
    url="$(tail -1 "$(_dashboard_state_file)")"
    echo "Dashboard already running at $url"
    if [ -z "${DASHBOARD_NO_OPEN:-}" ]; then
      open "$url" 2>/dev/null || true
    fi
    return
  fi

  local template_dir="$CLAWFLOWS_DIR/system/dashboard"
  local template="$template_dir/template.html"
  local server="$template_dir/server.js"

  [ -f "$template" ] || die "dashboard template not found at $template"
  [ -f "$server" ] || die "dashboard server not found at $server"
  command -v node >/dev/null 2>&1 || die "node is required for the dashboard (install Node.js)"

  local port="${DASHBOARD_PORT:-0}"
  local cli_path
  cli_path="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
  # If this script is a symlink, resolve to the real path
  if [ -L "$0" ]; then
    cli_path="$(readlink "$0")"
  fi

  # Use a FIFO to read the server's URL from its first stdout line
  local fifo
  fifo="$(mktemp -d)/dashboard-fifo"
  mkfifo "$fifo"

  # Start Node server in background, detached from terminal
  nohup node "$server" "$port" "$cli_path" "$template" > "$fifo" 2>/dev/null &
  local server_pid=$!
  disown "$server_pid" 2>/dev/null || true

  # Read the URL from the first line
  local url
  read -r url < "$fifo"

  # Keep draining the FIFO so the server doesn't block, then clean up
  (cat "$fifo" >/dev/null; rm -f "$fifo"; rmdir "$(dirname "$fifo")" 2>/dev/null) &
  disown 2>/dev/null || true

  # Save state (PID on line 1, URL on line 2)
  local state_file
  state_file="$(_dashboard_state_file)"
  printf '%s\n%s\n' "$server_pid" "$url" > "$state_file"

  echo "Dashboard running at $url"
  echo "Stop with: clawflows dashboard stop"
  echo ""

  # Open in browser (skip if DASHBOARD_NO_OPEN is set, e.g. in tests)
  if [ -z "${DASHBOARD_NO_OPEN:-}" ]; then
    open "$url" 2>/dev/null || true
  fi
}

# ── Main ────────────────────────────────────────────────────────────────────

[ $# -ge 1 ] || { cmd_help; exit 0; }

case "$1" in
  list)      cmd_list "${2:-all}" ;;
  create)    cmd_create "${2:-}" "${3:-}" ;;
  run)       [ $# -ge 2 ] || die "usage: clawflows run <name>"; cmd_run "$2" ;;
  logs)      cmd_logs "${2:-}" "${3:-}" ;;
  enable)    [ $# -ge 2 ] || die "usage: clawflows enable <name>"; cmd_enable "$2" ;;
  disable)   [ $# -ge 2 ] || die "usage: clawflows disable <name>"; cmd_disable "$2" ;;
  edit)      [ $# -ge 2 ] || die "usage: clawflows edit <name>"; cmd_edit "$2" ;;
  open)      [ $# -ge 2 ] || die "usage: clawflows open <name>"; cmd_open "$2" ;;
  validate)  [ $# -ge 2 ] || die "usage: clawflows validate <name>"; cmd_validate "$2" ;;
  submit)    [ $# -ge 2 ] || die "usage: clawflows submit <name>"; cmd_submit "$2" ;;
  share)     [ $# -ge 2 ] || die "usage: clawflows share <name>"; cmd_share "$2" "${3:-}" ;;
  import)    [ $# -ge 2 ] || die "usage: clawflows import <url>"; cmd_import "$2" ;;
  backup)    cmd_backup "${2:-}" ;;
  restore)   cmd_restore "${2:-}" ;;
  update)    cmd_update ;;
  dashboard) cmd_dashboard "${2:-}" ;;
  uninstall) cmd_uninstall ;;
  sync-agent) cmd_sync ;;
  doctor)    cmd_doctor ;;
  help|--help|-h) cmd_help ;;
  *)         cmd_help ;;
esac
